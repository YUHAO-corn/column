---
import Layout from "../layouts/Layout.astro";
import StatsDashboard from "../components/StatsDashboard.astro";
import ReadFlow from "../components/ReadFlow.astro";
import { getStats } from "../utils/stats";
import { SITE_META } from "../utils/site-meta";

const stats = getStats();
---

<Layout
  title="AI 产品决策专栏"
  description="一个产品人用 AI 从 0 到 1 做产品的全过程记录"
>
  <section class="hero-panel animate-lift-in">
    <div class="hero-label">Build Log / Decision Chronicle</div>
    <h1 class="hero-title">AI 产品决策专栏</h1>
    <p class="hero-desc">
      一个产品人用 AI 从 0 到 1 做产品的全过程记录。这里不是结果展示，而是每次取舍、每个判断、每条决策背后的真实推演。
    </p>
    <div class="hero-status mt-4">
      <span class="hero-status-chip">{SITE_META.status}</span>
      <span class="hero-status-chip">{SITE_META.stage}</span>
      <span class="hero-status-chip">{SITE_META.version}</span>
      <span class="hero-status-text">最近更新 {SITE_META.lastUpdated} · {SITE_META.updateNote}</span>
    </div>
    <div class="mt-5 flex flex-wrap gap-2">
      <a class="nav-chip nav-chip-primary nav-chip-large" href="#read-start">直接阅读内容</a>
    </div>
  </section>

  <StatsDashboard {...stats} />
  <ReadFlow />
</Layout>
